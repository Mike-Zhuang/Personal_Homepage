{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Frontend: Hugo Build",
            "type": "shell",
            "command": "hugo --gc --minify",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Frontend: Hugo Dev Server",
            "type": "shell",
            "command": "hugo server --bind 127.0.0.1 --port 1313 --buildDrafts --disableFastRender --environment development",
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Backend: FastAPI Dev Server",
            "type": "shell",
            "command": "./scripts/dev-api.sh",
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}