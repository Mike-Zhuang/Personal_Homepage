{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Frontend: Validate Template Asset Paths",
            "type": "shell",
            "command": "./scripts/check-template-asset-paths.sh",
            "problemMatcher": []
        },
        {
            "label": "Frontend: Hugo Build",
            "type": "shell",
            "command": "./scripts/check-template-asset-paths.sh && hugo --gc --minify",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Frontend: Hugo Dev Server",
            "type": "shell",
            "command": "./scripts/check-template-asset-paths.sh && hugo server --bind 127.0.0.1 --port 1313 --buildDrafts --disableFastRender --environment development",
            "problemMatcher": []
        },
        {
            "label": "Backend: FastAPI Dev Server",
            "type": "shell",
            "command": "API_DEV_LOG_FILE=./runtime/logs/api-dev.log ./scripts/dev-api.sh",
            "problemMatcher": []
        }
    ]
}
