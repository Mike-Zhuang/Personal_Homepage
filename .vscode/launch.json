{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Frontend: Hugo Dev Server",
            "type": "node-terminal",
            "request": "launch",
            "command": "cd \"${workspaceFolder}\" && ./scripts/check-template-asset-paths.sh && hugo server --bind 127.0.0.1 --port 1313 --buildDrafts --disableFastRender --environment development"
        },
        {
            "name": "Backend: FastAPI Dev Server",
            "type": "node-terminal",
            "request": "launch",
            "command": "cd \"${workspaceFolder}\" && API_DEV_LOG_FILE=./runtime/logs/api-dev.log ./scripts/dev-api.sh"
        },
        {
            "name": "Preview: Open Homepage",
            "type": "node-terminal",
            "request": "launch",
            "command": "sleep 2 && open http://127.0.0.1:1313"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack: Run",
            "configurations": [
                "Backend: FastAPI Dev Server",
                "Frontend: Hugo Dev Server"
            ],
            "stopAll": true
        }
    ]
}
