CONTACT_PLACEHOLDER_MODE=true
CONTACT_LOG_PATH=/opt/personal-homepage/runtime/contact-messages.log
CORS_ALLOW_ORIGINS=https://example.com,http://127.0.0.1:1313,http://localhost:1313
# 注意：example 文件禁止填写真实密钥
ADMIN_API_KEY=change-this-admin-key
# 线上建议把可编辑内容放到 git 工作区之外，避免宝塔 git pull 与 admin 保存互相冲突
DATA_ROOT=/opt/personal-homepage/runtime/live-data
ADMIN_BACKUP_ROOT=/opt/personal-homepage/runtime/backups
ADMIN_BACKUP_LIMIT=10
CONTENT_PUBLISH_SCRIPT=/opt/personal-homepage/deploy/scripts/publish-content.sh
# 可选：线上建议显式指定发布目录；本机未设置时会自动回退到 runtime/site-preview
# SITE_ROOT=/var/www/personal-homepage/frontend/dist
# 可选：本地开发时可把后端日志写入文件（脚本仍会实时打印到终端）
# API_DEV_LOG_FILE=/opt/personal-homepage/runtime/logs/api-dev.log
ADMIN_AUTO_PUBLISH_ON_SAVE=true
